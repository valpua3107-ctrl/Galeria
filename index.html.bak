п»ҝ<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BananIA - Inteligencia Artificial para el Cultivo Bananero</title>
  <meta name="description"
    content="Herramienta de inteligencia artificial para detectar y clasificar automГғВЎticamente el estado fitosanitario de hojas de banano en fincas de exportaciГғВіn.">
  <link rel="stylesheet" href="styles.css">
</head>

<body>
  <!-- ==========================================================================
       BARRA DE NAVEGACIГғвҖңN FIJA REUTILIZABLE
       ========================================================================== -->
  <header class="main-navbar" id="navbar">
    <div class="navbar-container">
      <a href="index.html" class="navbar-brand">
        <!-- Logotipo BananIA minimalista inline SVG -->
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="36" height="36" fill="none">
          <circle cx="20" cy="20" r="18" fill="#E8EDE7" />
          <path d="M12 28C15 14 26 10 29 11C31 12 30 16 26 21C22 26 15 29 12 28Z" fill="#70806A" opacity="0.85" />
          <path d="M14 26C18 16 26 13 28 14" stroke="#3E2E21" stroke-width="1.8" stroke-linecap="round" />
          <circle cx="25" cy="15" r="1.5" fill="#E2EDE0" />
        </svg>
        <span>BananIA</span>
      </a>

      <button class="navbar-toggle" id="navbarToggle" aria-label="Abrir menГғВә de navegaciГғВіn" aria-expanded="false"
        aria-controls="navbarMenu">
        <span></span>
        <span></span>
        <span></span>
      </button>

      <ul class="navbar-menu" id="navbarMenu">
