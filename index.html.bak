        <li><a href="proyectos.html" class="navbar-link">Proyectos</a></li>
        <li><a href="escaner.html" class="navbar-link">EscГғВЎner IA</a></li>
        <li><a href="mapa.html" class="navbar-link">Mapa</a></li>
        <li><a href="galerias.html" class="navbar-link">GalerГғВӯas</a></li>
